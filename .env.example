# AEGIS configuration — copy to `.env`, fill real values, NEVER commit `.env`.
# Secrets are loaded from the environment / secret manager ONLY (Principle 5).

# Environment: production | staging | development | test
AEGIS_ENV=production

# REQUIRED in production. >= 32 chars, high-entropy. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AEGIS_SECRET_KEY=

# REQUIRED if you use field-level encryption for PII. 256-bit key. Generate with:
#   python -c "from aegis.core.crypto import generate_field_key; print(generate_field_key())"
AEGIS_FIELD_ENCRYPTION_KEY=

# Hot-path store. Empty => in-memory (single process, dev only).
AEGIS_REDIS_URL=redis://localhost:6379/0

# CORS allow-list (comma-separated). MUST be https:// and non-wildcard in production.
AEGIS_CORS_ORIGINS=https://app.example.com

# Reverse-proxy IPs/CIDRs allowed to set X-Forwarded-For (else XFF is ignored).
AEGIS_TRUSTED_PROXIES=10.0.0.0/8

# Optional overrides
# AEGIS_REQUIRE_TLS=true
# AEGIS_JWT_ALGORITHM=HS256
# AEGIS_DISABLED_MODULES=
