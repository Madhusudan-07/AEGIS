# Mandatory senior review on security-critical paths (spec §7).
# Replace @AEGIS-security-leads with your real reviewing team/users before relying on this.
# Branch protection must have "Require review from Code Owners" enabled for this to bind.

# Crypto, auth, secrets — never merge without senior security review.
/aegis/core/crypto.py              @AEGIS-security-leads
/aegis/core/modules/authn.py       @AEGIS-security-leads
/aegis/core/modules/authz.py       @AEGIS-security-leads
/aegis/core/modules/secrets.py     @AEGIS-security-leads
/aegis/core/modules/encryption.py  @AEGIS-security-leads

# The ratchet + its guard are security-critical: changes need senior review (§6, §7).
/security/ratchet/                 @AEGIS-security-leads
/tests/regression/                 @AEGIS-security-leads

# CI gates and the agent: changing these changes the loop's guarantees.
/.github/workflows/                @AEGIS-security-leads
/security/agent/                   @AEGIS-security-leads
