# Secrets must never be committed (spec: no secrets in repo).
# NOTE: keep these specific — an unanchored `secrets.*` also matches the SOURCE module
# aegis/core/modules/secrets.py and silently drops it from the repo.
.env
*.env
*.key
*.pem
secrets.json
secrets.yaml
secrets.yml
secrets.txt
.secrets

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.hypothesis/
.venv/
venv/
sbom.json

# CI / runtime artifacts (regenerated by the battery; never committed)
reports/
*.pid
